# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Project ref — the subdomain of your Supabase URL (used by nx deploy and nx db:push)
# Find it: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_PROJECT_REF=<project-ref>

# ── GitHub Webhook ─────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=<your-webhook-secret>

# ── OpenTelemetry → Dash0 ─────────────────────────────────────────────────────
# Get your Dash0 OTLP endpoint: Settings → Organization → Endpoints
# Get your auth token:          Settings → Auth Tokens → Create Token
OTEL_SERVICE_NAME=lorekit
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=https://ingress.us-east-1.aws.dash0.com
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <DASH0_AUTH_TOKEN>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_RESOURCE_ATTRIBUTES=deployment.environment.name=production

# Activate OTel auto-instrumentation (ESM project — use --import)
# NODE_OPTIONS=--import @opentelemetry/auto-instrumentations-node/register

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info

# ── Development console exporter (no Dash0 needed locally) ────────────────────
# Uncomment to see spans in stdout instead of sending to Dash0:
# OTEL_TRACES_EXPORTER=console
# OTEL_METRICS_EXPORTER=console
