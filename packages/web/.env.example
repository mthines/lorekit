# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-publishable-key>
NEXT_PUBLIC_SUPABASE_PROJECT_REF=<project-ref>

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── Dash0 Server-side OTel (OTLP → Dash0) ─────────────────────────────────────
# These are already set via OTEL_* env vars — same token as the MCP server.
# Vercel auto-injects VERCEL_GIT_COMMIT_SHA for service.version.
OTEL_SERVICE_NAME=lorekit-web

# ── Dash0 Client-side RUM (browser → Dash0) ───────────────────────────────────
# Create a SEPARATE auth token with Ingesting-only permissions.
# This token IS PUBLIC — it is embedded in the browser bundle.
# Endpoint: https://app.dash0.com/settings/endpoints → OTLP via HTTP
# Token:    https://app.dash0.com/settings/auth-tokens → Create (Ingesting only)
NEXT_PUBLIC_DASH0_OTLP_ENDPOINT=https://ingress.us-east-1.aws.dash0.com
NEXT_PUBLIC_DASH0_AUTH_TOKEN=<ingesting-only-auth-token>
