{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "module": "nodenext",
    "target": "ES2022",
    "moduleResolution": "nodenext",
    "rootDir": "../../",
    "composite": false
  },
  "include": ["src/**/*.ts", "../mcp-core/src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "../mcp-core/src/**/*.spec.ts", "../mcp-core/src/**/*.test.ts"]
}
