{
  "name": "@lorekit/cli",
  "version": "1.0.0",
  "description": "Install the LoreKit shared-memory skill and run health checks for the LoreKit MCP server.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lorekit": "bin/lorekit.mjs"
  },
  "files": [
